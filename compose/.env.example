# Copy to .env.dev / .env.staging / .env.prod and fill in.
# Compose loads with: docker compose --env-file compose/.env.<env> ...

# Project name — drives auto-prefixing of every network and volume so
# multiple envs (dev/staging/prod) can run on one host without colliding.
# Use food-delivery-dev / food-delivery-staging / food-delivery-prod.
COMPOSE_PROJECT_NAME=food-delivery-dev

# Image registry. Each service is tagged independently; set per-service
# tags below for staging/prod (see .env.staging / .env.prod). Dev uses the
# `:dev` tag built locally by `docker compose ... build`.
REGISTRY=food-delivery
IMAGE_TAG=latest

# Per-service image tags — required for staging/prod overlays. The base
# compose falls back to IMAGE_TAG if a service-specific tag isn't set,
# and to `latest` if neither is set (dev convenience).
# USER_SERVICE_TAG=v1.1.0
# RESTAURANT_SERVICE_TAG=v1.1.0
# ORDER_SERVICE_TAG=v3.0.0
# PAYMENT_SERVICE_TAG=v2.0.0
# DISPATCH_SERVICE_TAG=v1.0.0
# FRONTEND_TAG=v1.3.0

# JWT
JWT_ISSUER=user-service

# Per-service Postgres credentials
USERS_DB_USER=users
USERS_DB_PASSWORD=changeme
ORDERS_DB_USER=orders
ORDERS_DB_PASSWORD=changeme
PAYMENTS_DB_USER=payments
PAYMENTS_DB_PASSWORD=changeme
DISPATCH_DB_USER=dispatch
DISPATCH_DB_PASSWORD=changeme

# Restaurants Mongo
RESTAURANTS_DB_USER=restaurants
RESTAURANTS_DB_PASSWORD=changeme
RESTAURANTS_DB_NAME=restaurants

# RabbitMQ
RABBIT_USER=guest
RABBIT_PASSWORD=guest

# Order service tunables
DELIVERY_FEE_MINOR=3000
LOCATION_TTL_SECONDS=120

# Payment service tunables
DEFAULT_PAYMENT_METHOD=mock-card

# Dispatch service tunables
OFFER_TIMEOUT_MS=12000
DISPATCH_LOCK_TTL_S=60
SEARCH_RADIUS_M=3000
HEARTBEAT_STALE_MS=30000
