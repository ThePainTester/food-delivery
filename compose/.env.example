# Copy to .env.dev / .env.staging / .env.prod and fill in.
# Compose loads with: docker compose --env-file compose/.env.<env> ...

# Project name — drives auto-prefixing of every network and volume so
# multiple envs (dev/staging/prod) can run on one host without colliding.
# Use food-delivery-dev / food-delivery-staging / food-delivery-prod.
COMPOSE_PROJECT_NAME=food-delivery-dev

# Image registry + tag (used by staging/prod overrides)
REGISTRY=food-delivery
IMAGE_TAG=latest

# JWT
JWT_ISSUER=user-service

# Per-service Postgres credentials
USERS_DB_USER=users
USERS_DB_PASSWORD=changeme
ORDERS_DB_USER=orders
ORDERS_DB_PASSWORD=changeme
PAYMENTS_DB_USER=payments
PAYMENTS_DB_PASSWORD=changeme

# Restaurants Mongo
RESTAURANTS_DB_USER=restaurants
RESTAURANTS_DB_PASSWORD=changeme
RESTAURANTS_DB_NAME=restaurants

# RabbitMQ
RABBIT_USER=guest
RABBIT_PASSWORD=guest

# Order service tunables
DELIVERY_FEE_CENTS=250
LOCATION_TTL_SECONDS=120

# Payment service tunables
DEFAULT_PAYMENT_METHOD=mock-card
